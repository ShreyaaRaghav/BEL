# ==========================================
# Comprehensive Gitignore for BEL Project
# Covers Python, Node.js/React/Vite, IDEs,
# OS, and Database components.
# ==========================================

# --- Sensitive Data & Environments ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.*
! .env.example
secrets.json
*.pem
*.key
*.cert

# --- Node.js & React (Frontend & Frontend-App) ---
node_modules/
**/node_modules/
jspm_packages/
.npm
.eslintcache
.stylelintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Frontend Build & Cache ---
dist/
dist-ssr/
build/
**/dist/
**/build/
.cache/
.vite/
.parcel-cache/
.next/
out/
.nuxt/
.docusaurus/

# --- Python (Backend & AI Engine) ---
# Byte-compiled / optimized / DLL files
__pycache__/
*.pyc
*.pyo
*.pyd
**/__pycache__/

# Python environments
venv/
.venv/
env/
ENV/
**/venv/
**/env/
**/.venv/
*venv*/
*env*/
pip-log.txt
pip-delete-this-directory.txt

# Python testing & coverage
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.noserc
.cache
.mypy_cache/
.pyre/
.pytype/
ipython_log.py

# Python builds & distributions
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Databases & SQLite ---
*.sqlite
*.sqlite3
*.db
*.db-journal
*.db-shm
*.db-wal
**/*.sqlite
**/*.sqlite3
**/*.db

# --- Logs & Diagnostics ---
logs/
*.log
*.log.*
**/logs/
debug.log

# --- IDEs & Editors ---
# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/settings.json

# JetBrains (PyCharm, WebStorm, etc.)
.idea/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Other Editors & Temp files
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*~
\#*\#
.#*

# --- OS-specific files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini